{
  "model_schema_version": "model.schema.v1",
  "required_plugins": [
    {
      "id": "generic-graph",
      "version": "2026.07.22"
    },
    {
      "id": "archimate-oef",
      "version": "2026.07.22"
    }
  ],
  "nodes": [
    {
      "id": "contracts",
      "type": "ApplicationComponent",
      "label": "contracts",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "0",
        "rationale": "Shared protocol vocabulary: command envelopes, diagnostics, schema-version constants, and the record/enum families for layout/render/export/source/plugin. The stable kernel; its real product surface is the JSON schemas under schemas/, of which these records are the typed projection.",
        "evidence": "source-backed",
        "source": "contracts/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "ir",
      "type": "ApplicationComponent",
      "label": "ir",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "0.5",
        "rationale": "Typed IR spine \u2014 the SceneGraph / LaidOutScene seam types that engine-api speaks (Plan B P4). Sits between contracts and engine-api.",
        "evidence": "source-backed",
        "source": "ir/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "archimate",
      "type": "ApplicationComponent",
      "label": "archimate",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "1",
        "rationale": "ArchiMate notation core: the type vocabulary and semantic validation for ArchiMate source models. Depends on nothing internal.",
        "evidence": "source-backed",
        "source": "archimate/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "uml",
      "type": "ApplicationComponent",
      "label": "uml",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "1",
        "rationale": "UML notation core: the type vocabulary and semantic validation for UML source models.",
        "evidence": "source-backed",
        "source": "uml/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "schema-cache",
      "type": "ApplicationComponent",
      "label": "schema-cache",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "1",
        "rationale": "Small utility core that fetches and caches external standards schemas for export validation.",
        "evidence": "source-backed",
        "source": "schema-cache/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "engine-api",
      "type": "ApplicationComponent",
      "label": "engine-api",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "1",
        "rationale": "The typed engine seam: SemanticsEngine / LayoutEngine / RenderEngine / ExportEngine interfaces. Interfaces only; depends on contracts and ir.",
        "evidence": "source-backed",
        "source": "engine-api/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "core",
      "type": "ApplicationComponent",
      "label": "core",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "Orchestration and backend-neutral policy: command handlers, the build driver, in-memory engine dispatch, schema/source validation, and layout-quality checks. Drives engines only through engine-api.",
        "evidence": "source-backed",
        "source": "core/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "semantics-graph",
      "type": "ApplicationComponent",
      "label": "semantics-graph",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "Profile-routing semantics engine (wire id still generic-graph) plus base scene projection. Dispatches to the per-notation front ends.",
        "evidence": "source-backed",
        "source": "semantics-graph/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "semantics-archimate",
      "type": "ApplicationComponent",
      "label": "semantics-archimate",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "ArchiMate notation front end: the per-notation legality checks the router dispatches to. Depends on the archimate core.",
        "evidence": "source-backed",
        "source": "semantics-archimate/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "semantics-uml",
      "type": "ApplicationComponent",
      "label": "semantics-uml",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "UML notation front end: the per-notation legality checks the router dispatches to. Depends on the uml core.",
        "evidence": "source-backed",
        "source": "semantics-uml/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "elk-layout",
      "type": "ApplicationComponent",
      "label": "elk-layout",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "The Eclipse ELK Layered layout engine: computes node geometry and edge routes.",
        "evidence": "source-backed",
        "source": "engines/elk-layout/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "render",
      "type": "ApplicationComponent",
      "label": "render",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "The SVG render engine: owns styling and marker policy. The only engine that touches both notation cores.",
        "evidence": "source-backed",
        "source": "engines/render/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "archimate-oef-export",
      "type": "ApplicationComponent",
      "label": "archimate-oef-export",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "ArchiMate Open Exchange Format (OEF) compatibility export engine. Validates in-JVM via schema-cache.",
        "evidence": "source-backed",
        "source": "engines/archimate-oef-export/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "uml-xmi-export",
      "type": "ApplicationComponent",
      "label": "uml-xmi-export",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "2",
        "rationale": "UML/XMI compatibility export engine. Validates in-JVM via schema-cache.",
        "evidence": "source-backed",
        "source": "engines/uml-xmi-export/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "mcp-server",
      "type": "ApplicationComponent",
      "label": "mcp-server",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "3",
        "rationale": "MCP stdio protocol adapter: marshals tool calls into core commands and returns the same envelopes verbatim. Owns no orchestration or engine construction.",
        "evidence": "source-backed",
        "source": "mcp-server/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "cli",
      "type": "ApplicationComponent",
      "label": "cli",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "3",
        "rationale": "The thin entrypoint and composition root: parses arguments, assembles a request, calls core, prints the envelope. EngineWiring is the one class that constructs the engine implementations.",
        "evidence": "source-backed",
        "source": "cli/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    },
    {
      "id": "dist-tool",
      "type": "ApplicationComponent",
      "label": "dist-tool",
      "properties": {
        "layer": "Application",
        "viewpoint": "Application Cooperation",
        "tier": "3",
        "rationale": "Assembly and distribution: bundles the single cli launcher (hosting the engines in-process), generates third-party notices and the SBOM, and runs the dist smoke. Top of the graph.",
        "evidence": "source-backed",
        "source": "dist-tool/pom.xml; docs/architecture-guidelines.md \u00a72\u2013\u00a73"
      }
    }
  ],
