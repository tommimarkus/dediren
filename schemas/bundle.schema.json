{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dediren.dev/schemas/bundle.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_schema_version",
    "product",
    "version",
    "target",
    "built_at_utc",
    "schemas_dir",
    "fixtures_dir",
    "docs_dir"
  ],
  "properties": {
    "bundle_schema_version": { "const": "dediren-bundle.schema.v2" },
    "product": { "const": "dediren" },
    "version": { "type": "string", "minLength": 1 },
    "target": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "built_at_utc": { "type": "string", "minLength": 1 },
    "schemas_dir": { "type": "string", "minLength": 1 },
    "fixtures_dir": { "type": "string", "minLength": 1 },
    "docs_dir": { "type": "string", "minLength": 1 }
  }
}
