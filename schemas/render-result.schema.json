{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dediren.dev/schemas/render-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["render_result_schema_version", "artifacts"],
  "properties": {
    "render_result_schema_version": { "const": "render-result.schema.v5" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_kind", "content"],
        "properties": {
          "artifact_kind": { "enum": ["svg"] },
          "content": { "type": "string" },
          "encoding": { "enum": ["utf-8"] }
        }
      }
    }
  }
}
