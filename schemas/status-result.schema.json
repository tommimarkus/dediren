{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dediren.dev/schemas/status-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["status_result_schema_version", "models", "artifacts"],
  "properties": {
    "status_result_schema_version": { "const": "status-result.schema.v1" },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "status"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "status": { "enum": ["current", "stale", "unstamped"] },
          "model_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
