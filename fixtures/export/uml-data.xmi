<xmi:XMI xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmlns:uml="http://www.omg.org/spec/UML/20161101"><uml:Model xmi:id="id-dediren-uml-basic-model" name="Dediren UML Basic"><packagedElement xmi:type="uml:Class" xmi:id="id-class-order" name="Order"><ownedAttribute xmi:id="id-class-order-id" name="id" type="id-datatype-orderid" visibility="public"><lowerValue xmi:type="uml:LiteralInteger" xmi:id="id-class-order-id-lower" value="1"/><upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="id-class-order-id-upper" value="1"/></ownedAttribute><ownedAttribute xmi:id="id-class-order-status" name="status" type="id-enum-order-status" visibility="private"><lowerValue xmi:type="uml:LiteralInteger" xmi:id="id-class-order-status-lower" value="1"/><upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="id-class-order-status-upper" value="1"/></ownedAttribute><ownedOperation xmi:id="id-class-order-submit" name="submit" visibility="public"/></packagedElement><packagedElement xmi:type="uml:Enumeration" xmi:id="id-enum-order-status" name="OrderStatus"><ownedLiteral xmi:id="id-enum-order-status-draft" name="Draft"/><ownedLiteral xmi:id="id-enum-order-status-submitted" name="Submitted"/><ownedLiteral xmi:id="id-enum-order-status-cancelled" name="Cancelled"/></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="id-class-order-line" name="OrderLine"><ownedAttribute xmi:id="id-class-order-line-sku" name="sku" type="id-primitive-string" visibility="public"><lowerValue xmi:type="uml:LiteralInteger" xmi:id="id-class-order-line-sku-lower" value="1"/><upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="id-class-order-line-sku-upper" value="1"/></ownedAttribute><ownedAttribute xmi:id="id-class-order-line-quantity" name="quantity" type="id-primitive-integer" visibility="public"><lowerValue xmi:type="uml:LiteralInteger" xmi:id="id-class-order-line-quantity-lower" value="1"/><upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="id-class-order-line-quantity-upper" va