<xmi:XMI xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmlns:uml="http://www.omg.org/spec/UML/20161101"><uml:Model xmi:id="id-dediren-uml-basic-model" name="Dediren UML Basic"><packagedElement xmi:type="uml:StateMachine" xmi:id="id-order-lifecycle" name="Order Lifecycle"><region xmi:id="id-main-region" name="Main Region"><subvertex xmi:type="uml:Pseudostate" xmi:id="id-initial" name="" kind="initial"/><subvertex xmi:type="uml:State" xmi:id="id-draft" name="Draft"/><subvertex xmi:type="uml:State" xmi:id="id-submitted" name="Submitted"/><subvertex xmi:type="uml:Pseudostate" xmi:id="id-payment-choice" name="" kind="choice"/><subvertex xmi:type="uml:State" xmi:id="id-fulfilled" name="Fulfilled"/><subvertex xmi:type="uml:FinalState" xmi:id="id-closed" name=""/><subvertex xmi:type="uml:FinalState" xmi:id="id-rejected" name=""/><transition xmi:id="id-t-create" name="create" source="id-initial" target="id-draft" kind="external"></transition><transition xmi:id="id-t-submit" name="submit" source="id-draft" target="id-submitted" kind="external"></transition><transition xmi:id="id-t-check-payment" name="authorize" source="id-submitted" target="id-payment-choice" kind="external"></transition><transition xmi:id="id-t-approve" name="[paymentAuthorized]" source="id-payment-choice" target="id-fulfilled" kind="external"><guard xmi:type="uml:Constraint" xmi:id="id-t-approve-guard" name="paymentAuthorized"><specification xmi:type="uml:OpaqueExpression" xmi:id="id-t-approve-guard-specification"><body>paymentAuthorized</body></specification></guard></transition><transition xmi:id="id-t-reject" name="[paymentRejected]" source="id-payment-choice" target="id-rejected" kind="external"><guard xmi:type="uml:Constraint" xmi:id="id-t-reject-guard" name="paymentRejected"><specification xmi:type="uml:OpaqueExpression" xmi:id="id-t-reject-guard-specification"><body>paymentRejected</body></specification></guard></transition><transition xmi:id="id-t-close" name="deliver" source="id-fulfilled" target="id-closed" kind="external"></transition></region></packagedElement></uml:Model></xmi:XMI>
