<xmi:XMI xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmlns:uml="http://www.omg.org/spec/UML/20161101"><uml:Model xmi:id="id-dediren-uml-basic-model" name="Dediren UML Basic"><packagedElement xmi:type="uml:Activity" xmi:id="id-activity-submit-order" name="Submit Order"><node xmi:type="uml:InitialNode" xmi:id="id-initial-submit"/><node xmi:type="uml:OpaqueAction" xmi:id="id-action-enter-order" name="Enter order"/><node xmi:type="uml:DecisionNode" xmi:id="id-decision-valid" name="Valid?"/><node xmi:type="uml:OpaqueAction" xmi:id="id-action-submit" name="Submit"/><node xmi:type="uml:ActivityFinalNode" xmi:id="id-final-submit"/><edge xmi:type="uml:ControlFlow" xmi:id="id-flow-start-enter" source="id-initial-submit" target="id-action-enter-order"/><edge xmi:type="uml:ControlFlow" xmi:id="id-flow-enter-valid" source="id-action-enter-order" target="id-decision-valid"/><edge xmi:type="uml:ControlFlow" xmi:id="id-flow-valid-submit" name="yes" source="id-decision-valid" target="id-action-submit"><guard xmi:type="uml:OpaqueExpression" xmi:id="id-flow-valid-submit-guard"><body>valid</body></guard></edge><edge xmi:type="uml:ControlFlow" xmi:id="id-flow-submit-final" source="id-action-submit" target="id-final-submit"/><group xmi:type="uml:ActivityPartition" xmi:id="id-activity-submit-order-partition-customer" name="Customer" node="id-initial-submit id-action-enter-order"/><group xmi:type="uml:ActivityPartition" xmi:id="id-activity-submit-order-partition-order-service" name="Order Service" node="id-decision-valid id-action-submit id-final-submit"/></packagedElement></uml:Model></xmi:XMI>
