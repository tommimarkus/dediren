      "type": "CombinedFragment",
      "label": "Availability",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "operator": "alt",
          "operands": ["op-in-stock", "op-backorder"],
          "covered": ["customer", "service", "inventory"]
        }
      }
    },
    {
      "id": "op-in-stock",
      "type": "InteractionOperand",
      "label": "In Stock",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "combined_fragment": "cf-availability",
          "order": 1,
          "guard": "inStock",
          "fragments": ["m1", "m2"]
        }
      }
    },
    {
      "id": "op-backorder",
      "type": "InteractionOperand",
      "label": "Backorder",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "combined_fragment": "cf-availability",
          "order": 2,
          "guard": "else",
          "fragments": ["m3", "m4"]
        }
      }
    },
    {
      "id": "cf-coupon",
      "type": "CombinedFragment",
      "label": "Coupon",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "operator": "opt",
          "operands": ["op-coupon"],
          "covered": ["customer", "service"]
        }
      }
    },
    {
      "id": "op-coupon",
      "type": "InteractionOperand",
      "label": "Coupon Present",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "combined_fragment": "cf-coupon",
          "order": 1,
          "guard": "couponPresent",
          "fragments": ["m5", "m6"]
        }
      }
    },
    {
      "id": "cf-retry",
      "type": "CombinedFragment",
      "label": "Retry Authorization",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "operator": "loop",
          "operands": ["op-retry"],
          "covered": ["service", "payment"]
        }
      }
    },
    {
      "id": "op-retry",
      "type": "InteractionOperand",
      "label": "Retry",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "combined_fragment": "cf-retry",
          "order": 1,
          "guard": "whilePaymentPending",
          "fragments": ["m7", "m8"]
        }
      }
    },
    {
      "id": "cf-parallel-closeout",
      "type": "CombinedFragment",
      "label": "Parallel Closeout",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "operator": "par",
          "operands": ["op-charge", "op-confirm"],
          "covered": ["customer", "service", "payment"]
        }
      }
    },
    {
      "id": "op-charge",
      "type": "InteractionOperand",
      "label": "Charge",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order",
          "combined_fragment": "cf-parallel-closeout",
          "order": 1,
          "guard": "charge",
          "fragments": ["m9", "m10"]
        }
      }
    },
    {
      "id": "op-confirm",
      "type": "InteractionOperand",
