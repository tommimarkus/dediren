      "type": "Lifeline",
      "label": "Customer",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order"
        }
      }
    },
    {
      "id": "service",
      "type": "Lifeline",
      "label": "Order Service",
      "properties": {
        "uml": {
          "interaction": "interaction-place-order"
        }
      }
    },
    {
