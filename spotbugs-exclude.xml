<?xml version="1.0" encoding="UTF-8"?>
<!-- SpotBugs suppression filter. Every <Match> below is tracked known debt:
     add a matching row to docs/architecture-guidelines.md §12 stating the
     reason. Do not suppress silently.
     See docs/superpowers/specs/2026-07-01-spotless-spotbugs-quality-gates-design.md §3 -->
<FindBugsFilter>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: two distinct cases, enumerated per class
       (not a blanket pattern-wide suppression) because their justification
       differs. The contracts.* records (and the ir.* SceneGraph/SceneGroup/
       LaidOutScene/PlacedGroup/RoutedEdge records, which follow the identical
       construction discipline) wrap their List/Map components via
       ContractCollections.listOrEmpty(...)/mapOrEmpty(...)/copyOrNull(...)
       (List.copyOf/Map.copyOf), so the shared reference is genuinely
       immutable. (copyOrNull preserves null for optional dash_pattern
       overrides, where null "inherit" differs from an empty list.)
       schemacache.SchemaFetchResult is different: it holds mutable byte[]
       stdout/stderr exposed by reference (arrays are never immutable in
       Java); it is not part of the public contracts surface, but a
       short-lived internal schema-cache result whose buffers are never
       mutated after construction. Defensive-copying either case is out of
       scope for wiring the quality gate. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.contracts.build.BuildArtifact"/>
      <Class name="dev.dediren.contracts.build.BuildResult"/>
      <Class name="dev.dediren.contracts.build.BuildViewOutcome"/>
      <Class name="dev.dediren.contracts.layout.LaidOutEdge"/>
      <Class name="dev.dediren.contracts.layout.LaidOutGroup"/>
      <Class name="dev.dediren.contracts.layout.LayoutConstraint"/>
      <Class name="dev.dediren.contracts.layout.LayoutGroup"/>
      <Class name="dev.dediren.contracts.layout.LayoutRequest"/>
      <Class name="dev.dediren.contracts.layout.LayoutResult"/>
      <Class name="dev.dediren.contracts.analysis.DiffResult$EntityChanges"/>
      <Class name="dev.dediren.contracts.analysis.DiffResult$ChangedEntity"/>
      <Class name="dev.dediren.contracts.analysis.DiffResult$ChangedView"/>
      <Class name="dev.dediren.contracts.analysis.DiffResult$ViewChanges"/>
      <Class name="dev.dediren.contracts.analysis.QueryResult$Dependents"/>
      <Class name="dev.dediren.contracts.analysis.QueryResult$Orphans"/>
      <Class name="dev.dediren.contracts.analysis.QueryResult$ViewCoverage"/>
      <Class name="dev.dediren.contracts.analysis.VerifyResult"/>
      <Class name="dev.dediren.contracts.analysis.StatusResult"/>
      <Class name="dev.dediren.contracts.export.OefExportPolicy"/>
      <Class name="dev.dediren.contracts.render.RenderMetadata"/>
      <Class name="dev.dediren.contracts.render.RenderResult"/>
      <Class name="dev.dediren.contracts.render.SvgStylePolicy"/>
      <Class name="dev.dediren.contracts.render.SvgNodeStyle"/>
      <Class name="dev.dediren.contracts.render.SvgGroupStyle"/>
      <Class name="dev.dediren.contracts.render.SvgEdgeStyle"/>
      <Class name="dev.dediren.contracts.render.SvgGradient"/>
      <Class name="dev.dediren.contracts.source.GenericGraphPluginData"/>
      <Class name="dev.dediren.contracts.source.GenericGraphView"/>
      <Class name="dev.dediren.contracts.source.GenericGraphViewGroup"/>
      <Class name="dev.dediren.contracts.source.SourceDocument"/>
      <Class name="dev.dediren.contracts.source.SourceNode"/>
      <Class name="dev.dediren.contracts.source.SourceRelationship"/>
      <Class name="dev.dediren.schemacache.SchemaFetchResult"/>
      <Class name="dev.dediren.ir.SceneGraph"/>
      <Class name="dev.dediren.ir.SceneGroup"/>
      <Class name="dev.dediren.ir.LaidOutScene"/>
      <Class name="dev.dediren.ir.PlacedGroup"/>
      <Class name="dev.dediren.ir.RoutedEdge"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: the engine-api value types follow the
       same construction discipline as the contracts.* records above:
       EngineResult and EngineException wrap their List<Diagnostic> component
       via ContractCollections.listOrEmpty(...) (List.copyOf), and Engines
       wraps its four capability maps via mapOrEmpty(...)/Map.copyOf, so the
       shared reference is genuinely immutable. Suppressed rather than
       defensive-copied for consistency with the contracts records. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.engine.EngineException"/>
      <Class name="dev.dediren.engine.EngineResult"/>
      <Class name="dev.dediren.engine.Engines"/>
      <Class name="dev.dediren.engine.ModelExportRequest"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: EngineDispatch.InMemoryOutcome.Failure is
       the core in-memory dispatch failure outcome (Plan B P4). It follows the
       identical construction discipline as the engine-api value types above:
       its List<Diagnostic> component is wrapped via
       ContractCollections.listOrEmpty(...) (List.copyOf) in the compact
       constructor, so the shared reference is genuinely immutable. Suppressed
       rather than defensive-copied for consistency with the contracts.* /
       engine-api records. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.core.engine.EngineDispatch$InMemoryOutcome$Failure"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: semantics-uml.SequenceConstraint's four
       records (LifelineOrder, MessageOrder, FragmentOpen, OperandOpen; Plan B
       P5 Task 2) follow the identical construction discipline as the
       contracts.* / ir.* records above: each wraps its List<String> component
       via ContractCollections.listOrEmpty(...) (List.copyOf) in a compact
       constructor, so the shared reference is genuinely immutable. Suppressed
       rather than defensive-copied for consistency with the contracts/ir
       records. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.semantics.uml.SequenceConstraint$LifelineOrder"/>
      <Class name="dev.dediren.semantics.uml.SequenceConstraint$MessageOrder"/>
      <Class name="dev.dediren.semantics.uml.SequenceConstraint$FragmentOpen"/>
      <Class name="dev.dediren.semantics.uml.SequenceConstraint$OperandOpen"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: ir.LayoutIntent's sole record variant
       (OrderedBand; Plan B P5 Task 1) follows the identical construction
       discipline as the contracts.* / ir.* / semantics-uml records above: it
       wraps its List<BandMember> component via
       ContractCollections.listOrEmpty(...) (List.copyOf) in a compact
       constructor, so the shared reference is genuinely immutable.
       ir.BandMember (String id, double leadingGap) holds no List/Map
       component and SpotBugs does not flag it, so it is intentionally not
       listed here. Suppressed rather than defensive-copied for consistency
       with the contracts/ir/semantics-uml records. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.ir.LayoutIntent$OrderedBand"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- MS_EXPOSE_REP: JsonSupport.objectMapper() intentionally returns the
       shared ObjectMapper singleton. It is mutable in place (.configure(),
       .registerModule()) and exposed by design (one canonical mapper). The
       reconfiguration risk is first-party-only: every consumer of the
       singleton is first-party code in the product JVM, and the mapper is
       configured once at class initialization. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.contracts.json.JsonSupport"/>
    <Bug pattern="MS_EXPOSE_REP"/>
  </Match>

  <!-- NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: Path.getFileName()/getParent()
       return values dereferenced for entries produced by Files.list(dir) or for
       real bundle/output file paths. The null branch is infeasible for these
       inputs; adding defensive null handling would require defining new
       behavior for cases that cannot occur here. Build/dist tool, not shipped
       runtime. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.tools.dist.DistTool"/>
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: NodeLabelLines (render), the
       Resolved{Node,Group,Edge}Style render-style records (which wrap their
       optional List<Double> dash_pattern via ContractCollections.copyOrNull,
       genuinely immutable), and ExportScope (uml-xmi) are plugin-internal
       value records. They hold List/Set components consumed read-only within
       their engine; they are not part of the public JSON contract surface. As
       with the contracts.* records above, EI_EXPOSE_REP/REP2 is suppressed
       (SpotBugs cannot prove the copy immutable). Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.plugins.render.node.NodeLabelLines"/>
      <Class name="dev.dediren.plugins.render.style.ResolvedNodeStyle"/>
      <Class name="dev.dediren.plugins.render.style.ResolvedGroupStyle"/>
      <Class name="dev.dediren.plugins.render.style.ResolvedEdgeStyle"/>
      <Class name="dev.dediren.plugins.umlxmi.build.ExportScope"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

</FindBugsFilter>
