<?xml version="1.0" encoding="UTF-8"?>
<!-- SpotBugs suppression filter. Every <Match> below is tracked known debt:
     add a matching row to docs/architecture-guidelines.md §12 stating the
     reason. Do not suppress silently.
     See docs/superpowers/specs/2026-07-01-spotless-spotbugs-quality-gates-design.md §3 -->
<FindBugsFilter>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: two distinct cases, enumerated per class
       (not a blanket pattern-wide suppression) because their justification
       differs. The contracts.* records wrap their List/Map components via
       ContractCollections.listOrEmpty(...)/mapOrEmpty(...) (List.copyOf/
       Map.copyOf), so the shared reference is genuinely immutable.
       schemacache.SchemaFetchResult is different: it holds mutable byte[]
       stdout/stderr exposed by reference (arrays are never immutable in
       Java); it is not part of the public contracts surface, but a
       short-lived internal schema-cache result whose buffers are never
       mutated after construction. Defensive-copying either case is out of
       scope for wiring the quality gate. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.contracts.layout.LaidOutEdge"/>
      <Class name="dev.dediren.contracts.layout.LaidOutGroup"/>
      <Class name="dev.dediren.contracts.layout.LayoutConstraint"/>
      <Class name="dev.dediren.contracts.layout.LayoutGroup"/>
      <Class name="dev.dediren.contracts.layout.LayoutRequest"/>
      <Class name="dev.dediren.contracts.layout.LayoutResult"/>
      <Class name="dev.dediren.contracts.plugin.PluginManifest"/>
      <Class name="dev.dediren.contracts.plugin.RuntimeCapabilities"/>
      <Class name="dev.dediren.contracts.render.RenderMetadata"/>
      <Class name="dev.dediren.contracts.render.RenderResult"/>
      <Class name="dev.dediren.contracts.render.SvgStylePolicy"/>
      <Class name="dev.dediren.contracts.source.GenericGraphPluginData"/>
      <Class name="dev.dediren.contracts.source.GenericGraphView"/>
      <Class name="dev.dediren.contracts.source.GenericGraphViewGroup"/>
      <Class name="dev.dediren.contracts.source.SourceDocument"/>
      <Class name="dev.dediren.contracts.source.SourceNode"/>
      <Class name="dev.dediren.contracts.source.SourceRelationship"/>
      <Class name="dev.dediren.schemacache.SchemaFetchResult"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: the engine-api value types follow the
       same construction discipline as the contracts.* records above:
       EngineResult and EngineException wrap their List<Diagnostic> component
       via ContractCollections.listOrEmpty(...) (List.copyOf), and Engines
       wraps its four capability maps via mapOrEmpty(...)/Map.copyOf, so the
       shared reference is genuinely immutable. Suppressed rather than
       defensive-copied for consistency with the contracts records. Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.engine.EngineException"/>
      <Class name="dev.dediren.engine.EngineResult"/>
      <Class name="dev.dediren.engine.Engines"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- MS_EXPOSE_REP: JsonSupport.objectMapper() intentionally returns the
       shared ObjectMapper singleton. It is mutable in place (.configure(),
       .registerModule()) and exposed by design (one canonical mapper). The
       reconfiguration risk is first-party/same-JVM only: plugins communicate
       cross-process over stdin/stdout JSON, so this singleton never crosses a
       process/trust boundary. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.contracts.json.JsonSupport"/>
    <Bug pattern="MS_EXPOSE_REP"/>
  </Match>

  <!-- NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: Path.getFileName()/getParent()
       return values dereferenced for entries produced by Files.list(dir) or for
       real bundle/output file paths. The null branch is infeasible for these
       inputs; adding defensive null handling would require defining new
       behavior for cases that cannot occur here. Build/dist tool, not shipped
       runtime. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.tools.dist.DistTool"/>
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
  </Match>

  <!-- NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: PluginRunner.executablePath
       dereferences loaded.path().getParent(); a discovered manifest path always
       resolves under a plugins directory, so the parent is non-null in
       practice. Defining error behavior for the infeasible null-parent case is
       out of scope for the gate. Tracked in architecture-guidelines.md §12. -->
  <Match>
    <Class name="dev.dediren.core.plugins.PluginRunner"/>
    <Method name="executablePath"/>
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
  </Match>


  <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2: NodeLabelLines (render) and ExportScope
       (uml-xmi) are plugin-internal value records extracted from the former
       Main god-files during the god-file split. They hold List/Set components
       consumed read-only within their plugin; they are not part of the public
       JSON contract surface and never cross the process boundary. As with the
       contracts.* records above, EI_EXPOSE_REP/REP2 is suppressed rather than
       defensive-copied (out of scope for the gate). Tracked in
       architecture-guidelines.md §12. -->
  <Match>
    <Or>
      <Class name="dev.dediren.plugins.render.node.NodeLabelLines"/>
      <Class name="dev.dediren.plugins.umlxmi.build.ExportScope"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

</FindBugsFilter>
